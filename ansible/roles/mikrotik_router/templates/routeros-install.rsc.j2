# ============================================================
# {{ mikrotik_router_identity }} Production RouterOS Build
# VLAN segmented clean rebuild
# Version: {{ mikrotik_router_config_version }}
# Generated by: ansible/roles/mikrotik_router
# Security: contains secrets when rendered for apply; do not commit generated files
# ============================================================

# ------------------------------------------------------------
# 00 - Safety backup
# ------------------------------------------------------------
/system backup save name=pre-clean-rebuild
/export show-sensitive file=pre-clean-rebuild

{% if mikrotik_router_cleanup_enabled | bool %}
# ------------------------------------------------------------
# 01 - Clear existing configurable objects
# ------------------------------------------------------------
/ip firewall filter remove [find]
/ip firewall nat remove [find]
/ip firewall address-list remove [find]
/ip address remove [find]
/ip pool remove [find]
/ip dhcp-server remove [find]
/ip dhcp-server network remove [find]
/ip dhcp-server lease remove [find]
/ip dhcp-client remove [find]
/interface bridge port remove [find]
/interface bridge vlan remove [find]
/interface vlan remove [find]
/interface bridge remove [find name={{ mikrotik_router_bridge.name }}]
/interface list member remove [find]
/interface list remove [find]
/system logging remove [find topics=firewall,warning]
/system scheduler remove [find name=backup-daily]
/system script remove [find name=backup-daily]
/interface wifi configuration remove [find]
/interface wifi security remove [find]
/interface wifi datapath remove [find]
/interface wifi channel remove [find]
{% endif %}

# ------------------------------------------------------------
# 02 - Identity and system baseline
# ------------------------------------------------------------
/system identity set name={{ mikrotik_router_identity }}
/system clock set time-zone-name={{ mikrotik_router_timezone }}
/system note set show-at-login=yes note="{{ mikrotik_router_note }}"
/ipv6 settings set disable-ipv6={{ 'no' if mikrotik_router_enable_ipv6 | bool else 'yes' }}

# ------------------------------------------------------------
# 03 - Interface lists
# ------------------------------------------------------------
/interface list
{% for item in mikrotik_router_interface_lists %}
add name={{ item.name }} comment="{{ item.comment }}"
{% endfor %}

# ------------------------------------------------------------
# 04 - Bridge and VLAN interfaces
# ------------------------------------------------------------
/interface bridge
add name={{ mikrotik_router_bridge.name }} vlan-filtering=no protocol-mode={{ mikrotik_router_bridge.protocol_mode }} comment="{{ mikrotik_router_bridge.comment }}"

/interface vlan
add name={{ mikrotik_router_wan.vlan_interface }} interface={{ mikrotik_router_wan.interface }} vlan-id={{ mikrotik_router_wan.vlan_id }} comment="{{ mikrotik_router_wan.comment }}"
{% for vlan in mikrotik_router_vlans %}
add name=VLAN{{ vlan.id }}-{{ vlan.name }} interface={{ mikrotik_router_bridge.name }} vlan-id={{ vlan.id }} comment="{{ vlan.comment }} VLAN"
{% endfor %}

# ------------------------------------------------------------
# 05 - Bridge ports
# ------------------------------------------------------------
/interface bridge port
{% for port in mikrotik_router_ports %}
{% if port.mode == 'access' %}
add bridge={{ mikrotik_router_bridge.name }} interface={{ port.interface }} pvid={{ port.pvid }} frame-types={{ port.frame_types }} ingress-filtering={{ port.ingress_filtering }} comment="{{ port.comment }}"
{% else %}
add bridge={{ mikrotik_router_bridge.name }} interface={{ port.interface }} frame-types={{ port.frame_types }} ingress-filtering={{ port.ingress_filtering }} comment="{{ port.comment }}"
{% endif %}
{% endfor %}

# ------------------------------------------------------------
# 06 - Bridge VLAN table
# ------------------------------------------------------------
/interface bridge vlan
{% for vlan in mikrotik_router_vlans %}
add bridge={{ mikrotik_router_bridge.name }} vlan-ids={{ vlan.id }} tagged={{ vlan.tagged | join(',') }}{% if vlan.untagged | length > 0 %} untagged={{ vlan.untagged | join(',') }}{% endif %} comment="VLAN{{ vlan.id }} {{ vlan.name }}"
{% endfor %}

# ------------------------------------------------------------
# 07 - IP addressing
# ------------------------------------------------------------
/ip address
{% for vlan in mikrotik_router_vlans %}
add address={{ vlan.gateway }}/24 interface=VLAN{{ vlan.id }}-{{ vlan.name }} network={{ vlan.network }} comment="{{ vlan.name }} gateway"
{% endfor %}

# ------------------------------------------------------------
# 08 - WAN DHCP client
# ------------------------------------------------------------
/ip dhcp-client
add interface={{ mikrotik_router_wan.vlan_interface }} use-peer-dns={{ mikrotik_router_wan.use_peer_dns }} use-peer-ntp={{ mikrotik_router_wan.use_peer_ntp }} add-default-route={{ mikrotik_router_wan.add_default_route }} disabled=no comment="WAN DHCP client"

# ------------------------------------------------------------
# 09 - DNS
# ------------------------------------------------------------
/ip dns
set servers={{ mikrotik_router_dns_fallback_servers | join(',') }} allow-remote-requests=yes cache-size=4096KiB

# ------------------------------------------------------------
# 10 - DHCP pools
# ------------------------------------------------------------
/ip pool
{% for vlan in mikrotik_router_vlans %}
add name=pool-vlan{{ vlan.id }} ranges={{ vlan.pool }}
{% endfor %}

# ------------------------------------------------------------
# 11 - DHCP servers and networks
# ------------------------------------------------------------
/ip dhcp-server
{% for vlan in mikrotik_router_vlans %}
add name=dhcp-vlan{{ vlan.id }} interface=VLAN{{ vlan.id }}-{{ vlan.name }} address-pool=pool-vlan{{ vlan.id }} authoritative=after-2sec-delay lease-time={{ vlan.lease_time }} disabled=no
{% endfor %}

/ip dhcp-server network
{% for vlan in mikrotik_router_vlans %}
add address={{ vlan.subnet }} gateway={{ vlan.gateway }} dns-server={{ mikrotik_router_dns_servers | join(',') }} domain={{ vlan.domain }} comment={{ vlan.name }}
{% endfor %}

# ------------------------------------------------------------
# 12 - Static lease placeholders
# ------------------------------------------------------------
/ip dhcp-server lease
{% for lease in mikrotik_router_static_leases %}
add address={{ lease.address }} comment={{ lease.comment }} disabled={{ lease.disabled }} server={{ lease.server }}
{% endfor %}

# ------------------------------------------------------------
# 13 - Address lists
# ------------------------------------------------------------
/ip firewall address-list
{% for network in mikrotik_router_rfc1918_networks %}
add list=RFC1918 address={{ network }} comment="Private RFC1918"
{% endfor %}
{% for vlan in mikrotik_router_vlans %}
add list=LANS address={{ vlan.subnet }} comment="VLAN{{ vlan.id }} {{ vlan.name }}"
{% endfor %}

# ------------------------------------------------------------
# 14 - Interface list members
# ------------------------------------------------------------
/interface list member
add list=WAN interface={{ mikrotik_router_wan.vlan_interface }}
add list=LAN interface={{ mikrotik_router_bridge.name }} comment="Bridge only"
{% for vlan in mikrotik_router_vlans %}
add list={{ vlan.interface_list }} interface=VLAN{{ vlan.id }}-{{ vlan.name }}
add list=INTERNAL interface=VLAN{{ vlan.id }}-{{ vlan.name }}
{% endfor %}

# ------------------------------------------------------------
# 15 - Wi-Fi baseline
# ------------------------------------------------------------
/interface wifi channel
{% for channel in mikrotik_router_wifi_channels %}
add band={{ channel.band }} name={{ channel.name }} skip-dfs-channels={{ channel.skip_dfs_channels }} width={{ channel.width }}
{% endfor %}

/interface wifi security
add name=sec-users authentication-types={{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'users') | first).auth }} passphrase="{{ mikrotik_router_wifi_passphrase_users }}"
add name=sec-mgmt authentication-types={{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'mgmt') | first).auth }} passphrase="{{ mikrotik_router_wifi_passphrase_mgmt }}"
add name=sec-iot authentication-types={{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'iot') | first).auth }} passphrase="{{ mikrotik_router_wifi_passphrase_iot }}"
add name=sec-guest authentication-types={{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'guest') | first).auth }} passphrase="{{ mikrotik_router_wifi_passphrase_guest }}"

/interface wifi datapath
{% for wifi in mikrotik_router_wifi_networks %}
add name={{ wifi.datapath }} bridge={{ mikrotik_router_bridge.name }} vlan-id={{ wifi.vlan_id }}
{% endfor %}

/interface wifi configuration
add name=cfg-users-5 channel=ch-5 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'users') | first).ssid }}" security=sec-users datapath=dp-users
add name=cfg-users-24 channel=ch-24 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'users') | first).ssid }}" security=sec-users datapath=dp-users
add name=cfg-mgmt-5 channel=ch-5 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'mgmt') | first).ssid }}" security=sec-mgmt datapath=dp-mgmt
add name=cfg-mgmt-24 channel=ch-24 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'mgmt') | first).ssid }}" security=sec-mgmt datapath=dp-mgmt
add name=cfg-iot-5 channel=ch-5 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'iot') | first).ssid }}" security=sec-iot datapath=dp-iot
add name=cfg-iot-24 channel=ch-24 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'iot') | first).ssid }}" security=sec-iot datapath=dp-iot
add name=cfg-guest-5 channel=ch-5 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'guest') | first).ssid }}" security=sec-guest datapath=dp-guest
add name=cfg-guest-24 channel=ch-24 country="{{ mikrotik_router_wifi_country }}" mode=ap ssid="{{ (mikrotik_router_wifi_networks | selectattr('key', 'equalto', 'guest') | first).ssid }}" security=sec-guest datapath=dp-guest

/interface wifi
{% for radio in mikrotik_router_wifi_radios %}
set [find default-name={{ radio.default_name }}] comment="{{ radio.comment }}" configuration={{ radio.configuration }} disabled=no
{% endfor %}
{% for wifi in mikrotik_router_virtual_wifi %}
add name={{ wifi.name }} master-interface={{ wifi.master }} configuration={{ wifi.configuration }} disabled=no
{% endfor %}

# ------------------------------------------------------------
# 16 - Firewall input chain
# ------------------------------------------------------------
/ip firewall filter
add action=accept chain=input comment="INPUT allow established" connection-state=established,related,untracked
add action=drop chain=input comment="INPUT drop invalid" connection-state=invalid
add action=accept chain=input comment="MGMT SSH Winbox - before brute force" dst-port=22,8291 in-interface-list=MGMT protocol=tcp
add action=accept chain=input comment="MGMT ping - before brute force" in-interface-list=MGMT protocol=icmp
add action=add-src-to-address-list address-list=mgmt_stage1 address-list-timeout=30s chain=input comment="Brute force stage 1" connection-state=new dst-port=22,8291 in-interface-list=WAN protocol=tcp
add action=add-src-to-address-list address-list=mgmt_stage2 address-list-timeout=1m chain=input comment="Brute force stage 2" dst-port=22,8291 in-interface-list=WAN protocol=tcp src-address-list=mgmt_stage1
add action=add-src-to-address-list address-list=mgmt_stage3 address-list-timeout=10m chain=input comment="Brute force stage 3" dst-port=22,8291 in-interface-list=WAN protocol=tcp src-address-list=mgmt_stage2
add action=add-src-to-address-list address-list=mgmt_blacklist address-list-timeout=1d chain=input comment="Brute force blacklist" dst-port=22,8291 in-interface-list=WAN protocol=tcp src-address-list=mgmt_stage3
add action=drop chain=input comment="Drop blacklisted sources" src-address-list=mgmt_blacklist
add action=accept chain=input comment="MGMT DNS DHCP NTP" dst-port=53,67,68,123 in-interface-list=MGMT protocol=udp
add action=accept chain=input comment="MGMT DNS TCP" dst-port=53 in-interface-list=MGMT protocol=tcp
add action=accept chain=input comment="MGMT remaining input" in-interface-list=MGMT
add action=accept chain=input comment="USERS DNS DHCP" dst-port=53,67,68 in-interface-list=USERS protocol=udp
add action=accept chain=input comment="USERS DNS TCP" dst-port=53 in-interface-list=USERS protocol=tcp
add action=accept chain=input comment="IOT DNS DHCP" dst-port=53,67,68 in-interface-list=IOT protocol=udp
add action=accept chain=input comment="IOT DNS TCP" dst-port=53 in-interface-list=IOT protocol=tcp
add action=accept chain=input comment="GUEST DNS DHCP" dst-port=53,67,68 in-interface-list=GUEST protocol=udp
add action=accept chain=input comment="GUEST DNS TCP" dst-port=53 in-interface-list=GUEST protocol=tcp
add action=drop chain=input comment="Drop WAN to router" in-interface-list=WAN
add action=drop chain=input comment="Drop all remaining input"

# ------------------------------------------------------------
# 17 - Firewall forward chain
# ------------------------------------------------------------
add action=accept chain=forward comment="FORWARD allow established" connection-state=established,related,untracked
add action=drop chain=forward comment="FORWARD drop invalid" connection-state=invalid
add action=accept chain=forward comment="Internal VLANs to internet" src-address-list=LANS out-interface-list=WAN
add action=drop chain=forward comment="Drop WAN to internal VLANs" in-interface-list=WAN dst-address-list=LANS
add action=accept chain=forward comment="MGMT to internal VLANs" dst-address-list=LANS src-address=192.168.20.0/24
add action=accept chain=forward comment="DNS to Technitium01 UDP" dst-address=192.168.30.10 dst-port=53 protocol=udp src-address-list=LANS
add action=accept chain=forward comment="DNS to Technitium01 TCP" dst-address=192.168.30.10 dst-port=53 protocol=tcp src-address-list=LANS
add action=accept chain=forward comment="DNS to Technitium02 UDP" dst-address=192.168.30.11 dst-port=53 protocol=udp src-address-list=LANS
add action=accept chain=forward comment="DNS to Technitium02 TCP" dst-address=192.168.30.11 dst-port=53 protocol=tcp src-address-list=LANS
add action=accept chain=forward comment="USERS to SERVERS web" dst-address=192.168.30.0/24 dst-port=80,443 protocol=tcp src-address=192.168.40.0/24
add action=drop chain=forward comment="IOT to SERVERS blocked" dst-address=192.168.30.0/24 src-address=192.168.50.0/24
add action=drop chain=forward comment="GUEST to internal blocked" dst-address-list=RFC1918 src-address=192.168.60.0/24
add action=drop chain=forward comment="DMZ to MGMT blocked" dst-address=192.168.20.0/24 src-address=192.168.90.0/24
add action=drop chain=forward comment="DMZ to STORAGE blocked" dst-address=192.168.70.0/24 src-address=192.168.90.0/24
add action=drop chain=forward comment="Drop all remaining inter-VLAN" dst-address-list=LANS src-address-list=LANS
add action=drop chain=forward comment="Drop all remaining forward"

# ------------------------------------------------------------
# 18 - NAT
# ------------------------------------------------------------
/ip firewall nat
add action=masquerade chain=srcnat comment="Internet NAT" out-interface-list=WAN

# ------------------------------------------------------------
# 19 - Management services
# ------------------------------------------------------------
/ip service
set ftp disabled=yes
set telnet disabled=yes
set www disabled=yes
set www-ssl address=192.168.20.0/24 disabled=no tls-version=only-1.2
set winbox address=192.168.20.0/24 disabled=no
set ssh address=192.168.20.0/24 disabled=no
set api disabled=yes
set api-ssl disabled=yes
/tool mac-server set allowed-interface-list=MGMT
/tool mac-server mac-winbox set allowed-interface-list=MGMT
/tool mac-server ping set enabled=no
/ip neighbor discovery-settings set discover-interface-list=MGMT

# ------------------------------------------------------------
# 20 - Logging and time
# ------------------------------------------------------------
/system logging
add topics=firewall,warning action=memory
add topics=critical,error,warning action=disk
/system ntp client set enabled=yes
/system ntp client servers remove [find]
{% for server in mikrotik_router_ntp_servers %}
/system ntp client servers add address={{ server }}
{% endfor %}

# ------------------------------------------------------------
# 21 - Automated local backup
# ------------------------------------------------------------
/system script
add name=backup-daily policy=read,write,test,sensitive source={
    :local date [/system clock get date]
    :local time [/system clock get time]
    :local cleanDate [:pick $date 0 4] . [:pick $date 5 7] . [:pick $date 8 10]
    :local cleanTime [:pick $time 0 2] . [:pick $time 3 5]
    :local backupName ("{{ mikrotik_router_identity }}-" . $cleanDate . "-" . $cleanTime)

    /system backup save name=$backupName
    /export show-sensitive file=$backupName
}
/system scheduler
add name=backup-daily interval=1d start-time=03:00:00 on-event=backup-daily

{% if mikrotik_router_enable_vlan_filtering_last | bool %}
# ------------------------------------------------------------
# 22 - Enable VLAN filtering last
# ------------------------------------------------------------
/interface bridge set {{ mikrotik_router_bridge.name }} vlan-filtering=yes
{% endif %}

# ------------------------------------------------------------
# 23 - Admin password and final verification commands
# ------------------------------------------------------------
/user set admin password="{{ mikrotik_router_admin_password }}"
/ip firewall filter print detail
/ip firewall nat print detail
/interface list member print
/ip firewall address-list print
/ip service print
/tool mac-server print
/tool mac-server mac-winbox print
/ping 1.1.1.1 src-address=192.168.20.1
